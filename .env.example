# SnapTriage Environment Variables
# Copy this file to .env.local and fill in the values

# ─── Database ──────────────────────────────────────────────
# Leave DATABASE_URL empty to use SQLite (default)
# Set to a Postgres connection string to use Postgres
DATABASE_URL=
SQLITE_PATH=./data/snaptriage.db

# ─── Auth.js (NextAuth v5) ─────────────────────────────────
# The core secret used by NextAuth to sign session cookies and derive encryption keys.
# Generate a secure 32-character base64 string using: npx auth secret
AUTH_SECRET=              

# The static cryptographic salt used to securely encrypt Personal Access Tokens (PATs) at rest.
# Required for security. Generate a secure random string (e.g., openssl rand -base64 32).
AUTH_SALT=

AUTH_URL=http://localhost:3000

# ─── GitHub OAuth ──────────────────────────────────────────
# Create at: https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ─── GitLab OAuth ──────────────────────────────────────────
# Create at: https://gitlab.com/-/user_settings/applications
# Callback URL: http://localhost:3000/api/auth/callback/gitlab
AUTH_GITLAB_ID=
AUTH_GITLAB_SECRET=
AUTH_GITLAB_URL=https://gitlab.com   # Self-hosted GitLab? Change this

# ─── Sync ──────────────────────────────────────────────────
SYNC_INTERVAL_MS=300000               # 5 minutes (default)
